{
    "annotations": {
        "list": []
    },
    "editable": true,
    "panels": [
        {
            "title": "🟢 Availability SLO — Error Rate < 1%",
            "description": "SLO: 99% of requests return non-5xx. Burns through error budget when above the red line.",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "percentunit",
                    "min": 0,
                    "max": 0.1,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "red",
                                "value": 0.01
                            }
                        ]
                    },
                    "custom": {
                        "thresholdsStyle": {
                            "mode": "line"
                        }
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "rideshare:http_errors:ratio5m",
                    "legendFormat": "5xx error rate",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "⏱ Latency SLO — p95 < 1s, p99 < 2.5s",
            "description": "SLO: 95th percentile latency under 1 second, 99th under 2.5 seconds.",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "s",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 0.5
                            },
                            {
                                "color": "red",
                                "value": 1.0
                            }
                        ]
                    },
                    "custom": {
                        "thresholdsStyle": {
                            "mode": "line"
                        }
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "rideshare:http_duration:p50",
                    "legendFormat": "p50",
                    "refId": "A"
                },
                {
                    "expr": "rideshare:http_duration:p95",
                    "legendFormat": "p95",
                    "refId": "B"
                },
                {
                    "expr": "rideshare:http_duration:p99",
                    "legendFormat": "p99",
                    "refId": "C"
                }
            ]
        },
        {
            "title": "📊 Request Throughput",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "reqps",
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "rideshare:http_requests:rate5m:total",
                    "legendFormat": "req/s",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "🚨 Active Alerts",
            "type": "stat",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "red",
                                "value": 1
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
                    "legendFormat": "firing",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "🎯 Error Budget Remaining (30d)",
            "description": "With a 99% SLO, you get a 1% error budget. This shows how much is left.",
            "type": "gauge",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "percentunit",
                    "min": 0,
                    "max": 1,
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 0.25
                            },
                            {
                                "color": "green",
                                "value": 0.5
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "1 - (rideshare:http_errors:ratio5m / 0.01)",
                    "legendFormat": "budget remaining",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "🏎 Surge Multiplier",
            "type": "gauge",
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 18,
                "y": 16
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "min": 1,
                    "max": 5,
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 1.5
                            },
                            {
                                "color": "orange",
                                "value": 2
                            },
                            {
                                "color": "red",
                                "value": 3
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "ride_surge_multiplier",
                    "legendFormat": "surge",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "📈 Rides by Status (rate/s)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 20
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "short"
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "rideshare:rides:rate5m",
                    "legendFormat": "{{status}}",
                    "refId": "A"
                }
            ]
        },
        {
            "title": "💰 Payment Amounts (p50)",
            "type": "timeseries",
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 20
            },
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "green"
                    },
                    "unit": "currencyUSD"
                },
                "overrides": []
            },
            "targets": [
                {
                    "expr": "rideshare:payment:p50",
                    "legendFormat": "median fare",
                    "refId": "A"
                }
            ]
        }
    ],
    "schemaVersion": 39,
    "tags": [
        "rideshare",
        "slo",
        "enterprise"
    ],
    "templating": {
        "list": [
            {
                "current": {
                    "selected": false,
                    "text": "Prometheus",
                    "value": "Prometheus"
                },
                "hide": 0,
                "includeAll": false,
                "name": "DS_PROMETHEUS",
                "query": "prometheus",
                "type": "datasource"
            }
        ]
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "title": "RideShare — SLO Overview",
    "uid": "rideshare-slo"
}